# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram supergroup chat ID (the forum group Reach listens in).
# Obtain via: forward a message from the group to @userinfobot
TELEGRAM_CHAT_ID=

# ─── Copilot SDK ─────────────────────────────────────────────────────────────

# GitHub token used to authenticate with the Copilot SDK.
# Needs the `copilot` OAuth scope. Optional if the SDK reads ~/.config/gh/hosts.yml.
COPILOT_TOKEN=

# ─── Session Storage ──────────────────────────────────────────────────────────

# Absolute path to the JSON file that persists session state across restarts.
# Default: %APPDATA%\reach\sessions.json
# SESSION_STORE_PATH=C:\Users\Aaron\AppData\Roaming\reach\sessions.json

# ─── Idle Backoff ─────────────────────────────────────────────────────────────

# How long (ms) before a session is considered idle. Default: 300000 (5 min)
# IDLE_TIMEOUT_MS=300000
