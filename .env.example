# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram supergroup chat ID (the forum group Reach listens in).
# Obtain via: forward a message from the group to @userinfobot
TELEGRAM_CHAT_ID=

# ─── Optional ────────────────────────────────────────────────────────────────

# LLM model to use. Default: claude-sonnet-4
# REACH_MODEL=claude-sonnet-4

# Tool approval policy. Default: approveAll
# Options: approveAll, denyAll, interactiveDestructive
# REACH_PERMISSION_POLICY=approveAll

# ─── Idle Backoff ─────────────────────────────────────────────────────────────

# How long (ms) before a session is considered idle. Default: 300000 (5 min)
# IDLE_TIMEOUT_MS=300000
